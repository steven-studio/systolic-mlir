# build 目录(cmake + ninja 产生的东西,不该进版本控制)
build/

# 编辑器/IDE
.vscode/
.idea/
*.swp

# 常见暂存档
*.o
*.a
*.so

# Vitis HLS artifacts
hls/*/systolic_proj/
hls/systolic_proj/
*.log
*.jou
.Xil/

# Vivado build artifacts (bitstreams, checkpoints, IP caches)
hls/*/vivado/build/
*.dcp
*.bit
*.jou
.Xil/

# Vitis HLS solution directories (regeneratable from run_hls.tcl)
hls/*/systolic_proj/

# Simulation waveform dumps and compiled testbenches (regeneratable via iverilog)
*.vcd
*.vvp

# Compiled test executables and Python caches in runtime/
runtime/test_fpga_conv2d
runtime/test_fpga_conv2d_auto
runtime/test_fpga_conv2d_general
runtime/test_fpga_matmul4x4
runtime/test_fpga_matmul_tiled
runtime/run_shape
runtime/__pycache__/
*.bak

# Scratch test vectors regenerated by run_shape.c / diagnose_ulp.py
runtime/*.bin

# Compiled NCHW conv2d test executable
runtime/test_fpga_conv2d_nchw

# Compiled batch_matmul test executable
runtime/test_fpga_batch_matmul

# Compiled vecmat test executable
runtime/test_fpga_vecmat
